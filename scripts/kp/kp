IMGS = ["torch", "tf", "parrot", "cupy", "jax", "matx", "thrust", "cuda", "arrayfire"]

LOGO_URL_SOURCES = [
    "https://raw.githubusercontent.com/codereport/parrot-cpp-extra/main/profiling/assets/{name}.png",
    "https://raw.githubusercontent.com/codereport/logos/main/{name}.png",
]

SIZE_SUFFIXES = {"K": 1_000, "M": 1_000_000, "B": 1_000_000_000}

# GPU memory-op accounting. nsys reports transfer sizes in MB (1e6 bytes).
H2D_OP = "[CUDA memcpy Host-to-Device]"
BYTES_PER_MB = 1_000_000

# Host-to-Device floor: minimum bytes copied to the device per input element
# (N). Runs that transfer less are assumed to have computed on the host and are
# excluded from the chart. Chosen below a bit-packed input (0.125 B/elem) yet
# far above the handful of bytes a host-offloaded answer copies back.
DEFAULT_MIN_H2D_BYTES_PER_N = 0.03


def fetch_logo(name, cache_buster):
    """Try each logo source in order; return a PIL Image or None."""
    last_err = None
    for url_template in LOGO_URL_SOURCES:
        url = url_template.format(name=name) + f"?cb={cache_buster}"
        try:
            with urlopen(url) as response:
                return Image.open(BytesIO(response.read()))
        except Exception as e:
            last_err = e
    print(f"Warning: Could not load image for {name}: {last_err}")
    return None


def parse_size(s):
    s = s.strip().upper()
    for suffix, multiplier in SIZE_SUFFIXES.items():
        if s.endswith(suffix):
            return int(float(s[:-1]) * multiplier)
    return int(s)


def format_size(n):
    for suffix, multiplier in reversed(list(SIZE_SUFFIXES.items())):
        if n >= multiplier and n % multiplier == 0:
            return f"{n // multiplier}{suffix}"
    return str(n)


def geometric_range(lower, upper):
    values = []
    val = lower
    while val <= upper:
        values.append(val)
        val *= 10
    return values


def remove_matching_angle_brackets(text, brackets):
    result = []
    stack = []
    for char in text:
        if char == brackets[0]:
            stack.append(len(result))
        elif char == brackets[1] and stack:
            start_idx = stack.pop()
            result = result[:start_idx]
        else:
            result.append(char)
    return "".join(result)


def after(s: str, t: str) -> str:
    return s[s.index(t) + len(t) :]


def before(s: str, t: str) -> str:
    return s[: s.index(t)]


def preprocess_kernel_name(name):
    backup = name
    name = remove_matching_angle_brackets(name, "<>")
    name = remove_matching_angle_brackets(name, "()")
    name = re.sub(r"void ", "", name)
    if "::" in name:
        name = "::".join(x for x in name.split("::") if not any(c.isdigit() for c in x))
        name = re.sub(r"::::", "::", name)
    if "kernel_agent" in name:
        inner = preprocess_kernel_name(after(backup, "<"))
        name = name.split("::")[-1]
        return f"{name}<{before(inner, ",")}>"
    return name.strip()


def load_kernel_data(file_path):
    try:
        data = pd.read_csv(file_path)
        data["Name"] = data["Name"].apply(preprocess_kernel_name)
        return data[["Name", "Total Time (ns)", "Instances"]]
    except Exception as e:
        print(f"Error reading {file_path}: {e}")
        return None


def load_memcpy_time(base_name):
    """Load GPU memcpy operations so their time counts toward the total.

    Returns a DataFrame with the same columns as ``load_kernel_data``
    (``Name``, ``Total Time (ns)``, ``Instances``) or ``None`` if unavailable.
    """
    path = base_name + "_cuda_gpu_mem_time_sum.csv"
    if not os.path.exists(path):
        return None
    try:
        data = pd.read_csv(path)
        data = data.rename(columns={"Operation": "Name", "Count": "Instances"})
        return data[["Name", "Total Time (ns)", "Instances"]]
    except Exception as e:
        print(f"Error reading {path}: {e}")
        return None


def load_h2d_bytes(base_name):
    """Total Host-to-Device bytes transferred for a run (0.0 if unknown)."""
    path = base_name + "_cuda_gpu_mem_size_sum.csv"
    if not os.path.exists(path):
        return 0.0
    try:
        data = pd.read_csv(path)
        h2d = data[data["Operation"] == H2D_OP]
        if h2d.empty:
            return 0.0
        return float(h2d["Total (MB)"].sum()) * BYTES_PER_MB
    except Exception as e:
        print(f"Error reading {path}: {e}")
        return 0.0


def resolve_n(subdir_path, n_value):
    """Determine the input size N: explicit sweep value, else ``n.txt``."""
    if n_value is not None:
        return n_value
    n_file = os.path.join(subdir_path, "n.txt")
    if os.path.exists(n_file):
        try:
            with open(n_file) as f:
                return int(f.read().strip())
        except Exception:
            return None
    return None


def h2d_floor_excluded(base_name, n, min_bytes_per_n, label):
    """Warn and return True when a run copies too little data to the device.

    A genuine GPU implementation must move its input onto the device, so its
    Host-to-Device transfer scales with N.  Runs that fall below the floor are
    assumed to have computed on the host and are excluded from the chart.
    Disabled when ``min_bytes_per_n <= 0`` or N is unknown.
    """
    if n is None or min_bytes_per_n <= 0:
        return False
    floor = min_bytes_per_n * n
    h2d = load_h2d_bytes(base_name)
    if h2d < floor:
        print(
            f"⚠️  Excluding '{label}': only {h2d:,.0f} B copied Host-to-Device "
            f"(< floor {floor:,.0f} B = {min_bytes_per_n} B/elem × N={n:,}). "
            "Computation likely ran on the host, not the GPU."
        )
        return True
    return False


def label_csv_files(base_name):
    """All per-run CSV artifacts for a given output base name."""
    return [base_name + "_" + report + ".csv" for report in CSV_REPORTS]


def rotate(lst, n):
    return lst[n:] + lst[:n]


def create_stacked_bar_chart(data_frames, labels, chart_name, export_html):
    sorted_data = sorted(
        zip(data_frames, labels),
        key=lambda pair: (
            pair[0]["Total Time (ns)"].sum() // (100 if "matx" in pair[1] else 1)
            if pair[0] is not None
            else 0
        ),
        reverse=True,
    )
    data_frames, labels = zip(*sorted_data)

    # Generate full version
    fig_full = _create_figure(
        data_frames,
        labels,
        chart_name,
        hoverlabel_size=30,
        show_annotations=True,
        top_margin=100,
    )

    if export_html:
        # Export full version
        pio.write_html(fig_full, file=f"{chart_name}_full.html", auto_open=False)

        # Generate and export mini version
        fig_mini = _create_figure(
            data_frames,
            labels,
            chart_name,
            hoverlabel_size=12,
            show_annotations=False,
            top_margin=75,
        )
        pio.write_html(fig_mini, file=f"{chart_name}_mini.html", auto_open=False)

    fig_full.show()


def _create_figure(
    data_frames, labels, chart_name, hoverlabel_size, show_annotations, top_margin
):
    """Helper function to create a figure with specific styling parameters."""
    fig = go.Figure()
    totals = []
    instance_counts = []
    color_palette = rotate(qualitative.Plotly, 7)
    n = len(qualitative.Plotly)

    for df, label in zip(data_frames, labels):
        if df is not None:
            div_factor = 100 if "matx" in label else 1
            totals.append(df["Total Time (ns)"].sum() // div_factor)
            instance_counts.append(df["Instances"].sum() // div_factor)
            for i, row in df.iterrows():
                fig.add_trace(
                    go.Bar(
                        name=row["Name"],
                        x=[label],
                        y=[row["Total Time (ns)"] / div_factor],
                        hoverinfo="text",
                        hoverlabel=dict(font_size=hoverlabel_size),
                        text=(
                            f"{row['Name']} "
                            f"({row['Total Time (ns)']} ns | {row['Instances']})"
                        ),
                        marker_color=color_palette[i % n],
                    )
                )

    max_total = max(totals)

    if show_annotations:
        for i, (total, count) in enumerate(zip(totals, instance_counts)):
            fig.add_annotation(
                x=labels[i],
                y=total,
                text=f"Total: {total:,} Kernels: {count}",
                showarrow=True,
                ax=0,
                ay=-40,
                font=dict(size=12, color="black"),
                align="center",
                bgcolor="rgba(255, 255, 255, 0.8)",
                borderpad=5,
                bordercolor="black",
                borderwidth=2,
            )

    # Add logo images
    cache_buster = int(time.time())
    for i, (total, count) in enumerate(zip(totals, instance_counts)):
        for name in IMGS:
            if name in labels[i]:
                img = fetch_logo(name, cache_buster)
                if img is not None:
                    fig.add_layout_image(
                        dict(
                            source=img,
                            xref="x",
                            yref="paper",
                            x=labels[i],
                            y=(
                                (total / max_total) + 0.075
                                if total < max_total * 0.75
                                else 0.025
                            ),
                            sizex=0.5,
                            sizey=0.5,
                            xanchor="center",
                            yanchor="bottom",
                        )
                    )
                break

    # Set smaller margins for mini version
    margin_settings = (
        dict(t=top_margin, l=60, r=40, b=60)
        if not show_annotations
        else dict(t=top_margin)
    )

    fig.update_layout(
        barmode="stack",
        title=f"CUDA Kernel Profiling ({chart_name})",
        yaxis_title="Total Time (ns)",
        hovermode="x",
        showlegend=False,
        bargap=0.2,
        margin=margin_settings,
    )

    return fig


def run_nsys(file_path, output_dir, verbose, n_value=None):
    base_name = os.path.splitext(os.path.basename(file_path))[0]
    if n_value is not None:
        base_name = f"{base_name}_n{n_value}"
    output_name = os.path.join(output_dir, base_name)
    file_path = os.path.abspath(file_path)
    command = [
        "nsys",
        "profile",
        "--trace=cuda",
        "-o",
        output_name,
    ]
    if file_path.endswith(".py"):
        command += ["python"]
    command += [file_path]
    if n_value is not None:
        command += [str(n_value)]

    nsys_rep = output_name + ".nsys-rep"
    sqlite_file = output_name + ".sqlite"
    qdstrm_file = output_name + ".qdstrm"

    try:
        if verbose:
            subprocess.run(command, check=True)
        else:
            result = subprocess.run(command, capture_output=True, text=True, check=True)
    except subprocess.CalledProcessError as e:
        print(f"Error running nsys on {file_path}: {e}")
        # Clean up any partial files that nsys might have created
        partial_files = [nsys_rep, sqlite_file, qdstrm_file]
        for file in partial_files:
            if os.path.exists(file):
                os.remove(file)
        return None, None
    return nsys_rep, sqlite_file


CSV_REPORTS = [
    "cuda_gpu_kern_sum",
    "cuda_api_sum",
    "cuda_gpu_mem_time_sum",
    "cuda_gpu_mem_size_sum",
]


def generate_csv(nsys_rep, base_name, verbose):
    command = ["nsys", "stats", "--force-overwrite", "true"]
    for report in CSV_REPORTS:
        command += ["--report", report]
    command += [
        "--format",
        ",".join("csv" for _ in CSV_REPORTS),
        "--output",
        ",".join(base_name for _ in CSV_REPORTS),
        nsys_rep,
    ]
    try:
        if verbose:
            subprocess.run(command, check=True)
        else:
            subprocess.run(command, capture_output=True, text=True)
    except subprocess.CalledProcessError as e:
        print(f"Error generating CSV files from {nsys_rep}: {e}")


def clean_up(files):
    for file in files:
        if os.path.exists(file):
            os.remove(file)


def run_profiler(args):
    subdir_path = os.path.join(os.getcwd(), args.subdir)
    files = [
        f for f in os.listdir(subdir_path) if f.endswith(".py") or f.endswith("_cu")
    ]

    if args.filter:
        files = [f for f in files if args.filter in f]

    output_dir = os.path.join(subdir_path, "nsys_results")
    os.makedirs(output_dir, exist_ok=True)

    for file in tqdm(files, desc="Profiling files"):
        file_path = os.path.join(subdir_path, file)
        if args.verbose:
            print(f"✅ Processing {file}...")
        nsys_rep, sqlite_file = run_nsys(file_path, output_dir, args.verbose)

        # Skip if profiling failed
        if nsys_rep is None:
            continue

        base_name = os.path.splitext(nsys_rep)[0]
        generate_csv(nsys_rep, base_name, args.verbose)
        clean_up([nsys_rep, sqlite_file])

        n = resolve_n(subdir_path, None)
        label = os.path.basename(base_name)
        if h2d_floor_excluded(base_name, n, args.min_h2d_bytes_per_n, label):
            clean_up(label_csv_files(base_name))


def run_sweep_profiler(args, n_values):
    subdir_path = os.path.join(os.getcwd(), args.subdir)
    files = [
        f for f in os.listdir(subdir_path) if f.endswith(".py") or f.endswith("_cu")
    ]

    if args.filter:
        files = [f for f in files if args.filter in f]

    output_dir = os.path.join(subdir_path, "nsys_results")
    os.makedirs(output_dir, exist_ok=True)

    results = {}
    failed = []
    total_runs = len(files) * len(n_values)

    with tqdm(total=total_runs, desc="Sweep profiling") as pbar:
        for file in files:
            label = os.path.splitext(file)[0]
            results[label] = {}
            for n_val in n_values:
                file_path = os.path.join(subdir_path, file)
                if args.verbose:
                    print(f"Processing {file} with N={format_size(n_val)}...")

                nsys_rep, sqlite_file = run_nsys(
                    file_path, output_dir, args.verbose, n_value=n_val
                )

                if nsys_rep is None:
                    failed.append((file, n_val))
                    pbar.update(1)
                    continue

                base_name = os.path.splitext(nsys_rep)[0]
                generate_csv(nsys_rep, base_name, args.verbose)

                csv_path = base_name + "_cuda_gpu_kern_sum.csv"
                df = load_kernel_data(csv_path)
                excluded = h2d_floor_excluded(
                    base_name,
                    n_val,
                    args.min_h2d_bytes_per_n,
                    f"{label} N={format_size(n_val)}",
                )
                if df is not None and not excluded:
                    total = df["Total Time (ns)"].sum()
                    mem_df = load_memcpy_time(base_name)
                    if mem_df is not None and not mem_df.empty:
                        total += mem_df["Total Time (ns)"].sum()
                    results[label][n_val] = total
                else:
                    failed.append((file, n_val))

                clean_up([nsys_rep, sqlite_file] + label_csv_files(base_name))
                pbar.update(1)

    if failed:
        print(f"\n⚠️  {len(failed)} run(s) failed:")
        for file, n_val in failed:
            print(f"   {file} N={format_size(n_val)}")
        print("Re-run with -v for details.\n")

    results = {k: v for k, v in results.items() if v}

    sweep_csv = os.path.join(output_dir, "sweep_results.csv")
    rows = []
    for label, n_times in results.items():
        for n_val, total_time in n_times.items():
            rows.append({"label": label, "N": n_val, "total_time_ns": total_time})
    pd.DataFrame(rows).to_csv(sweep_csv, index=False)

    return results


def _pretty_label(label):
    if label.endswith("_cu"):
        label = label[:-3]
    for name in sorted(IMGS, key=len, reverse=True):
        idx = label.find(name)
        if idx >= 0:
            return label[idx:]
    return label


LOGO_PX = 300


def _add_color_dot(img, hex_color):
    img = img.copy().convert("RGBA").resize((LOGO_PX, LOGO_PX), Image.LANCZOS)
    radius = 42
    overlay = Image.new("RGBA", (LOGO_PX, LOGO_PX), (0, 0, 0, 0))
    draw = ImageDraw.Draw(overlay)
    r, g, b = int(hex_color[1:3], 16), int(hex_color[3:5], 16), int(hex_color[5:7], 16)
    cx, cy = LOGO_PX - radius - 6, LOGO_PX - radius - 6
    draw.ellipse(
        [cx - radius, cy - radius, cx + radius, cy + radius],
        fill=(r, g, b, 255),
    )
    return Image.alpha_composite(img, overlay)


def create_line_chart(results, n_values, chart_name, export_html):
    fig = go.Figure()
    colors = [
        "#636EFA", "#EF553B", "#00CC96", "#AB63FA",
        "#FFA15A", "#19D3F3", "#FF6692", "#B6E880",
    ]

    sorted_items = sorted(
        results.items(), key=lambda kv: max(kv[1].values(), default=0)
    )
    n_lines = len(sorted_items)

    # Total-time traces (visible by default)
    for i, (label, n_times) in enumerate(sorted_items):
        xs = sorted(n_times.keys())
        ys = [n_times[x] for x in xs]
        fig.add_trace(
            go.Scatter(
                x=xs, y=ys,
                mode="lines+markers",
                name=_pretty_label(label),
                line=dict(color=colors[i % len(colors)], width=3),
                marker=dict(size=9),
                hovertemplate="%{y:,.0f} ns<extra>%{fullData.name}</extra>",
                visible=True,
            )
        )

    # Throughput traces (hidden by default)
    for i, (label, n_times) in enumerate(sorted_items):
        xs = sorted(n_times.keys())
        ys = [x / n_times[x] for x in xs]
        fig.add_trace(
            go.Scatter(
                x=xs, y=ys,
                mode="lines+markers",
                name=_pretty_label(label),
                line=dict(color=colors[i % len(colors)], width=3),
                marker=dict(size=9),
                hovertemplate="%{y:,.2f} N/ns<extra>%{fullData.name}</extra>",
                visible=False,
            )
        )

    slow_labels = {"cupy", "thrust"}
    img_cache = {}
    cache_buster = int(time.time())
    logo_size = 0.21

    slow_items = [(i, l, nt) for i, (l, nt) in enumerate(sorted_items)
                  if nt and _pretty_label(l) in slow_labels]
    fast_items = [(i, l, nt) for i, (l, nt) in enumerate(sorted_items)
                  if nt and _pretty_label(l) not in slow_labels]

    def _pil_to_uri(img):
        buf = BytesIO()
        img.save(buf, format="PNG")
        return "data:image/png;base64," + base64.b64encode(buf.getvalue()).decode()

    def _build_logo_dicts(top_items, bot_items):
        logo_dicts = []
        for items, y_pos in [(top_items, 0.88), (bot_items, 0.12)]:
            n_logos = len(items)
            for j, (i, label, _) in enumerate(items):
                paper_x = (j + 1) / (n_logos + 1)
                for name in IMGS:
                    if name in label:
                        if name not in img_cache:
                            img_cache[name] = fetch_logo(name, cache_buster)
                        base_img = img_cache.get(name)
                        if base_img is not None:
                            dotted = _add_color_dot(
                                base_img, colors[i % len(colors)]
                            )
                            logo_dicts.append(
                                dict(
                                    source=_pil_to_uri(dotted),
                                    xref="paper",
                                    yref="paper",
                                    x=paper_x,
                                    y=y_pos,
                                    sizex=logo_size,
                                    sizey=logo_size,
                                    xanchor="center",
                                    yanchor="middle",
                                )
                            )
                        break
        return logo_dicts

    logos_total = _build_logo_dicts(top_items=slow_items, bot_items=fast_items)
    logos_throughput = _build_logo_dicts(top_items=fast_items, bot_items=slow_items)

    for ld in logos_total:
        fig.add_layout_image(ld)

    vis_total = [True] * n_lines + [False] * n_lines
    vis_per_n = [False] * n_lines + [True] * n_lines

    fig.update_layout(
        template="plotly_white",
        title=dict(
            text=f"CUDA Kernel Profiling Sweep — {chart_name}",
            font=dict(size=22),
            x=0.5,
        ),
        xaxis=dict(
            title=dict(text="N (input size)", font=dict(size=15)),
            type="log",
            tickvals=n_values,
            ticktext=[format_size(n) for n in n_values],
            tickfont=dict(size=13),
            gridcolor="#E5E5E5",
            showline=True,
            linecolor="#CCCCCC",
        ),
        yaxis=dict(
            title=dict(text="Total Kernel Time (ns)", font=dict(size=15)),
            type="log",
            tickfont=dict(size=13),
            gridcolor="#E5E5E5",
            showline=True,
            linecolor="#CCCCCC",
        ),
        legend=dict(
            font=dict(size=14),
            orientation="h",
            x=0.5,
            y=-0.15,
            xanchor="center",
            yanchor="top",
        ),
        updatemenus=[
            dict(
                type="dropdown",
                direction="down",
                x=1.0,
                xanchor="right",
                y=1.15,
                yanchor="top",
                buttons=[
                    dict(
                        label="Total Time",
                        method="update",
                        args=[
                            {"visible": vis_total},
                            {
                                "yaxis.title.text": "Total Kernel Time (ns)",
                                "images": logos_total,
                            },
                        ],
                    ),
                    dict(
                        label="N / Time",
                        method="update",
                        args=[
                            {"visible": vis_per_n},
                            {
                                "yaxis.title.text": "Throughput (N/ns)",
                                "images": logos_throughput,
                            },
                        ],
                    ),
                ],
            )
        ],
        hovermode="x unified",
        margin=dict(t=100, l=80, r=40, b=100),
    )

    if export_html:
        pio.write_html(fig, file=f"{chart_name}_sweep.html", auto_open=False)

    fig.show()


def load_sweep_results(args):
    results_dir = os.path.join(args.subdir, "nsys_results")
    sweep_csv = os.path.join(results_dir, "sweep_results.csv")

    if not os.path.exists(sweep_csv):
        print(f"No sweep results found at {sweep_csv}")
        return None, None

    df = pd.read_csv(sweep_csv)
    results = {}
    for _, row in df.iterrows():
        label = row["label"]
        if label not in results:
            results[label] = {}
        results[label][int(row["N"])] = row["total_time_ns"]

    n_values = sorted(df["N"].unique().astype(int).tolist())
    return results, n_values


def run_plotter(args):
    results_dir = os.path.join(args.subdir, "nsys_results")
    data_frames = []
    labels = []
    if not os.path.isdir(results_dir):
        print(f"Directory {results_dir} does not exist or is invalid.")
        return

    suffix = "_cuda_gpu_kern_sum.csv"
    for file_name in os.listdir(results_dir):
        if file_name.endswith(suffix):
            file_path = os.path.join(results_dir, file_name)
            df = load_kernel_data(file_path)
            if df is not None:
                base_name = file_path[: -len(suffix)]
                mem_df = load_memcpy_time(base_name)
                if mem_df is not None and not mem_df.empty:
                    df = pd.concat([df, mem_df], ignore_index=True)
                data_frames.append(df)
                labels.append(file_name.replace(suffix, ""))

    if data_frames:
        create_stacked_bar_chart(data_frames, labels, args.subdir, args.export_html)
    else:
        print("No valid CSV files found in the directory.")


def main():
    parser = argparse.ArgumentParser(
        description="Run nsys profiling and generate plots."
    )
    parser.add_argument(
        "subdir",
        help="name of the subdirectory containing python files (e.g. sf2, mgc).",
    )
    parser.add_argument(
        "-p",
        "--plot-only",
        action="store_true",
        help="skip profiling and only generate plots",
    )
    parser.add_argument(
        "-np",
        "--no-plot",
        action="store_true",
        help="run profiling without displaying a plot",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="enable verbose output during profiling",
    )
    parser.add_argument(
        "-f",
        "--filter",
        help="only profile Python files containing this string",
    )
    parser.add_argument(
        "-e", "--export-html", help="export plot as HTML file", action="store_true"
    )
    parser.add_argument(
        "-n",
        "--sweep",
        nargs=2,
        metavar=("LOWER", "UPPER"),
        help="sweep N over geometric 10x range and produce a line chart (e.g. -n 10K 10M)",
    )
    parser.add_argument(
        "--min-h2d-bytes-per-n",
        type=float,
        default=DEFAULT_MIN_H2D_BYTES_PER_N,
        metavar="BYTES",
        help=(
            "floor for Host-to-Device bytes per input element (N). Runs that "
            "transfer less are assumed to compute on the host and are excluded "
            f"from the chart (default: {DEFAULT_MIN_H2D_BYTES_PER_N}; 0 disables). "
            "Requires N from --sweep or an n.txt in the subdir."
        ),
    )

    args = parser.parse_args()

    if args.sweep:
        lower = parse_size(args.sweep[0])
        upper = parse_size(args.sweep[1])
        n_values = geometric_range(lower, upper)
        if not args.plot_only:
            results = run_sweep_profiler(args, n_values)
        else:
            results, n_values = load_sweep_results(args)
            if results is None:
                return
        if not args.no_plot:
            create_line_chart(results, n_values, args.subdir, args.export_html)
    else:
        if not args.plot_only:
            run_profiler(args)
        if not args.no_plot:
            run_plotter(args)


if __name__ == "__main__":
    main()
